# Configurações de API
PROJECT_NAME="Desafio NL Consulting API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Banco de Dados (PostgreSQL para produção, SQLite para desenvolvimento local)
DATABASE_URL="postgresql+asyncpg://user:password@localhost/dbname"

# IA Keys (Substitua pelos seus valores reais)
OPENAI_API_KEY="sk-..."
GOOGLE_API_KEY="your-gemini-api-key"

# Logging (Grafana Loki)
LOKI_URL="https://logs-prod-us-central1.grafana.net/loki/api/v1/push"
LOKI_USER_ID="your-loki-user-id"
LOKI_TOKEN="your-loki-api-token"

# Segurança
SECRET_KEY="sua-chave-secreta-muito-segura"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
